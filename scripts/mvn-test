#!/usr/bin/env bash
# Run tests for a single module with a hard 90-second timeout.
# Exits 1 with a clear message if the command exceeds the limit.
#
# Usage: scripts/mvn-test <module> [extra maven args...]
# Example: scripts/mvn-test runtime
#          scripts/mvn-test quarkus-work-reports -Dtest=SlaBreachReportTest
#
# Why 90s? Maven @QuarkusTest suites for any single module complete in <60s on this machine.
# If a module exceeds 90s it means too many test classes are being run together — split the call.

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: scripts/mvn-test <module> [extra maven args...]" >&2
  exit 1
fi

MODULE="$1"
shift
EXTRA_ARGS=("$@")

JAVA_HOME=$(/usr/libexec/java_home -v 26)
export JAVA_HOME

# Hard limit: 90 seconds. If exceeded, print actionable guidance and exit 1.
TIMEOUT=90

echo "==> mvn test -pl ${MODULE} ${EXTRA_ARGS[*]:-} (timeout ${TIMEOUT}s)"

if ! timeout "${TIMEOUT}" mvn test -pl "${MODULE}" "${EXTRA_ARGS[@]}" 2>&1; then
  EXIT=$?
  if [ $EXIT -eq 124 ]; then
    echo ""
    echo "TIMEOUT: Module '${MODULE}' tests exceeded ${TIMEOUT}s." >&2
    echo "Fix: target a single test class with -Dtest=ClassName, or split the module." >&2
  fi
  exit $EXIT
fi
